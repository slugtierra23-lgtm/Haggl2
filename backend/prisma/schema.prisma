// ─── X (Twitter) connection ──────────────────────────────────────────────────
//
// One row per user. Holds the OAuth 2.0 access + refresh tokens we need
// to post on the user's behalf when one of their AI agents launches a
// token. Tokens are AES-256-GCM encrypted at rest with X_TOKEN_ENC_KEY
// so a DB leak doesn't hand the attacker live posting access.
//
// We store xUserId + screenName for display ("Posting as @handle") and
// scopes so the FE can show what the user authorised. expiresAt drives
// the silent refresh on every post attempt.

model XConnection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  xUserId    String // Twitter's numeric user id
  screenName String // @handle (no @ prefix)

  // Format: base64(iv) + ":" + base64(ciphertext) + ":" + base64(authTag)
  accessTokenEnc  String   @db.Text
  refreshTokenEnc String   @db.Text
  expiresAt       DateTime
  scopes          String // space-separated list, e.g. "tweet.read tweet.write users.read offline.access"

  // Per-user posting throttle so a runaway agent doesn't spam the user's
  // account into a suspension. Reset by the service every 24h on first
  // post of the new window.
  postsLast24h     Int      @default(0)
  postsWindowStart DateTime @default(now())

  @@map("x_connections")
}

// ─── Per-AI-agent X (Twitter) connection (BYO X App) ───────────────────────────
//
// Each AI_AGENT MarketListing brings its own X Developer App (Client ID +
// Secret) so the platform doesn't bottleneck on a shared API plan. The
// seller pastes their app credentials into the publish wizard, then runs
// the OAuth flow against THEIR app, which writes this row. All four
// secrets (clientId, clientSecret, accessToken, refreshToken) are
// AES-256-GCM encrypted at rest with TOKEN_CRYPTO_KEY.
//
// One connection per listing. Disconnect = delete the row.
model AgentXConnection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String        @unique
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // The seller's X Developer App credentials. Encrypted at rest because
  // they grant API access to anyone who reads them.
  clientIdEnc     String @db.Text
  clientSecretEnc String @db.Text

  // The X account the agent will tweet AS. Filled on completed OAuth.
  // Nullable because the row exists between "keys saved" and "OAuth done".
  xUserId    String?
  screenName String?

  // OAuth tokens — same encryption envelope as the user-level XConnection.
  accessTokenEnc  String?   @db.Text
  refreshTokenEnc String?   @db.Text
  expiresAt       DateTime?
  scopes          String?

  // ── OAuth 1.0a path (the simpler "paste 4 keys" flow) ──
  // X Free tier rejects POST /2/tweets via OAuth 2.0 with HTTP 402,
  // but the OAuth 1.0a path still works on Free for accounts that
  // have the endpoint enabled. We let the seller choose either path
  // — if any oauth1* field is set, the post path uses 1.0a; otherwise
  // it falls back to OAuth 2.0 (accessTokenEnc).
  oauth1ConsumerKeyEnc       String? @db.Text
  oauth1ConsumerSecretEnc    String? @db.Text
  oauth1AccessTokenEnc       String? @db.Text
  oauth1AccessTokenSecretEnc String? @db.Text

  postsLast24h     Int      @default(0)
  postsWindowStart DateTime @default(now())

  // ── Autonomous tweeting (Phase 2) ──
  // When `autonomousEnabled` is true, a backend cron polls the
  // listing's agent webhook every `postIntervalHours` and lets the
  // agent decide whether to tweet about its token. When
  // `requireApproval` is true (default), the agent's tweet proposals
  // land in `scheduledPosts` for a human click before posting; when
  // false the cron posts directly. `mentionsEnabled` opts the listing
  // into reply-to-mentions polling.
  autonomousEnabled    Boolean   @default(false)
  postIntervalHours    Int       @default(24)
  requireApproval      Boolean   @default(true)
  mentionsEnabled      Boolean   @default(false)
  lastAutonomousAt     DateTime?
  mentionsLastSyncedAt DateTime?
  // Last X tweet id we replied-to / acknowledged. Used as the
  // since_id pointer when polling /2/users/:id/mentions so we don't
  // process the same mention twice.
  lastMentionId        String?

  scheduledPosts AgentXScheduledPost[]

  @@map("agent_x_connections")
}

// ─── Autonomous tweet queue ──────────────────────────────────────────────────
//
// Every time the autonomous cron (or a manual decide-now hit) asks the
// agent webhook "should you tweet?", the agent's reply is materialised
// here. If the listing has `requireApproval = true` the row stays in
// PENDING_APPROVAL until a human clicks Approve / Reject; otherwise it
// is posted immediately and lands in POSTED (or FAILED with the X
// error verbatim).
//
// The same table backs mention-reply proposals (triggerType =
// MENTION_REPLY, with `inReplyToTweetId` set) so the queue UI is
// uniform.
model AgentXScheduledPost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FK to AgentXConnection.listingId — the listing's X connection
  // owns the queue. Cascade-delete so disconnecting the X account
  // also clears the queue.
  listingId  String
  connection AgentXConnection @relation(fields: [listingId], references: [listingId], onDelete: Cascade)

  text    String  @db.Text
  reason  String? @db.Text
  // Token / mention context the agent saw at decision time. Kept so
  // we can replay or audit "why did the agent suggest this tweet".
  context Json?

  status      AgentXPostStatus  @default(PENDING_APPROVAL)
  triggerType AgentXPostTrigger @default(SCHEDULED)

  // Only set when triggerType = MENTION_REPLY — the X tweet id we are
  // replying to.
  inReplyToTweetId String?

  // Filled once posted: X's tweet id + when it was posted. On failure
  // we capture the verbatim X error so the queue UI can render it.
  tweetId       String?
  failureReason String?   @db.Text
  postedAt      DateTime?

  @@index([listingId, status])
  @@index([createdAt])
  @@map("agent_x_scheduled_posts")
}

enum AgentXPostStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
  FAILED
}

enum AgentXPostTrigger {
  SCHEDULED
  MENTION_REPLY
  MANUAL
}

// ─── AI Agents (User-owned buyer negotiation agents) ────────────────────────────

model Agent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String // e.g., "Negotiation Bot v2"
  description String?     @db.Text
  status      AgentStatus @default(INACTIVE)
  webhookUrl  String      @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  metrics       AgentMetrics?
  activityLog   AgentActivityLog[]
  raysPurchases RaysPurchase[]
  rays          AgentRays?

  @@index([userId])
  @@map("agents")
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  TESTING
  ERROR
}

model AgentMetrics {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  totalCalls      Int       @default(0)
  successfulCalls Int       @default(0)
  failedCalls     Int       @default(0)
  avgResponseTime Int       @default(0) // in milliseconds
  lastCallAt      DateTime?

  agentId String @unique
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_metrics")
}

model AgentActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action       String // e.g., "webhook_call", "negotiation_started", "agreement_reached"
  status       ActivityStatus
  metadata     Json? // store context like negotiation details
  responseTime Int? // in milliseconds

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@map("agent_activity_logs")
}

enum ActivityStatus {
  SUCCESS
  FAILED
  PENDING
  TIMEOUT
}

// ─── RAYOS SYSTEM ──────────────────────────────────────────────────────────────

model RaysPurchase {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  raysPack    RaysPack // 10, 25, 50, 120, 250
  raysAmount  Int // Actual rays purchased
  boltyAmount Decimal // Amount paid in BOLTY

  txHash String? // Blockchain transaction hash (optional, for tracking)
  status PurchaseStatus @default(COMPLETED)

  @@index([userId, agentId])
  @@index([createdAt])
  @@map("rays_purchases")
}

enum RaysPack {
  PACK_10
  PACK_25
  PACK_50
  PACK_120
  PACK_250
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model AgentRays {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentId String @unique
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  totalRaysAccumulated Int       @default(0) // Total rayos de por vida
  currentRank          AgentRank @default(HIERRO)

  lastRankUpAt DateTime?
  rankHistory  RankHistory[]

  @@map("agent_rays")
}

enum AgentRank {
  HIERRO
  BRONCE
  PLATA
  ORO
  PLATINO
  DIAMANTE
  MAESTRIA
  CAMPEON
}

model RankHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  agentRaysId String
  agentRays   AgentRays @relation(fields: [agentRaysId], references: [id], onDelete: Cascade)

  previousRank AgentRank
  newRank      AgentRank
  totalRaysAt  Int

  @@index([agentRaysId, createdAt])
  @@map("rank_history")
}
