# ──────────────────────────────────────────────────────────────────────
# haggl backend — environment variables
# ──────────────────────────────────────────────────────────────────────
# Copy to `backend/.env` for local dev. On Render, the values marked
# ⤷ Render are wired automatically by render.yaml. The rest you set in
# the Render dashboard (Environment tab).

# ── Required (server crashes on boot if missing) ─────────────────────
# DATABASE_URL ⤷ Render provides via render.yaml
DATABASE_URL=postgresql://user:pass@localhost:5432/haggl?schema=public
# Direct connection — Prisma migrations + seed scripts use this.
DIRECT_URL=postgresql://user:pass@localhost:5432/haggl?schema=public
# REDIS_URL ⤷ Render provides via render.yaml
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000

# ── Auth + cookies ───────────────────────────────────────────────────
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=change-me
CSRF_SECRET=change-me
AGENT_HMAC_SECRET=change-me
# Comma-separated list of allowed origins. Local dev = frontend URL.
# Production: include the Vercel preview pattern + custom domain.
CORS_ORIGINS=http://localhost:3000
# Set to your apex domain in production (e.g. .haggl.tech) so the
# refresh-token cookie is shared between www and api subdomains.
COOKIE_DOMAIN=

# ── Server runtime ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
PRISMA_CONNECTION_LIMIT=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AI_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_MAX=60
CHAT_BOTS_DISABLED=false
SEED_LISTINGS_ON_BOOT=false
BOLTYGUARD_BACKFILL_ON_BOOT=false

# ── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=haggl <noreply@haggl.tech>

# ── OAuth: GitHub ────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── OAuth: X (Twitter) ───────────────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3001/api/v1/auth/twitter/callback
X_AGENT_REDIRECT_URI=http://localhost:3001/api/v1/agents/twitter/callback

# ── AI providers ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Web3 ─────────────────────────────────────────────────────────────
# Solana RPC — keep the key name as-is even though haggl is on Solana now.
# Existing escrow contract code reads ETH_RPC_URL.
ETH_RPC_URL=https://api.devnet.solana.com
HAGGL_TOKEN_ADDRESS=
HAGGL_TOKEN_CONTRACT=
HAGGL_TOKEN_DECIMALS=18
BOLTYGUARD_MIN_HOLDING=0

# ── External APIs ────────────────────────────────────────────────────
PRICE_API_URL=https://api.coingecko.com/api/v3
